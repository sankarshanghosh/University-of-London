<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reader Article Page - <%= article.title %>
    </title>
    <link rel="stylesheet" href="/main.css">
</head>

<body>
    <header>
        <h1>
            <%= settings.blog_title %>
        </h1>
        <h2>
            <%= settings.blog_subtitle %>
        </h2>
        <p>by <%= settings.author_name %>
        </p>
    </header>
    <h2 class="page-title">Reader: Article Page</h2>
    <article>
        <h2>
            <%= article.title %>
        </h2>
        <p>Subtitle: <%= article.subtitle %>
        </p>
        <p>Published: <%= new Date(article.published_at).toISOString().slice(0, 10) %>
        </p>
        <p>
            <%= article.body %>
        </p>
        <form action="/like-article" method="POST">
            <input type="hidden" name="articleId" value="<%= article.article_id %>">
            <button type="submit">Like <span class="reaction-count">
                    <%= likesCount %>
                </span></button>
        </form>
    </article>
    <section>
        <h3>Comments</h3>
        <form action="/post-comment" method="POST">
            <input type="hidden" name="articleId" value="<%= article.article_id %>">
            <input type="text" name="commenterName" placeholder="Your name" required>
            <textarea name="commentText" placeholder="Your comment" required></textarea>
            <button type="submit">Add Comment</button>
        </form>
        <ul>
            <% comments.forEach(function(comment) { %>
                <li>
                    <strong>
                        <%= comment.commenter_name %>:
                    </strong>
                    <%= comment.comment_text %>
                        <br>
                        <small>Posted: <%= new Date(comment.posted_at).toLocaleString() %></small>
                </li>
                <% }); %>
        </ul>
    </section>

    <footer>
        <a href="/reader-home">Back to Reader Home</a>
    </footer>
</body>

</html>